		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Price Band' =
			SWITCH(
			    TRUE(),
			    'gold FactListings'[PriceEUR] < 150, "Under €150",
			    'gold FactListings'[PriceEUR] < 250, "€150–249",
			    'gold FactListings'[PriceEUR] < 400, "€250–399",
			    "€400+"
			)
		dataType: string
		lineageTag: d9b7c0a1-1010-4c01-9001-000000000019
		summarizeBy: none

	column 'Distance Band' =
			SWITCH(
			    TRUE(),
			    'gold FactListings'[DistanceToCityCenterKM] <= 2, "Within 2 km",
			    'gold FactListings'[DistanceToCityCenterKM] <= 5, "2–5 km",
			    "Beyond 5 km"
			)
		dataType: string
		lineageTag: d9b7c0a1-1010-4c01-9001-000000000020
		summarizeBy: none

	column 'Satisfaction Band' =
			SWITCH(
			    TRUE(),
			    'gold FactListings'[GuestSatisfactionScore] < 90, "Below 90",
			    'gold FactListings'[GuestSatisfactionScore] < 95, "90–94",
			    "95+"
			)
		dataType: string
		lineageTag: d9b7c0a1-1010-4c01-9001-000000000021
		summarizeBy: none

	partition 'gold FactListings' = m
		mode: import
		source =
				let
				    Source = Sql.Database(".\SQLEXPRESS", "DataWareHouse"),
				    gold_FactListings = Source{[Schema="gold",Item="FactListings"]}[Data]
				in
				    gold_FactListings

	annotation PBI_ResultType = Table

