	column DistanceToCityCenterKM
		dataType: double
		lineageTag: 37b2a312-9142-41f6-94a2-d83c1448fa83
		summarizeBy: sum
		sourceColumn: DistanceToCityCenterKM

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column DistanceToMetroKM
		dataType: double
		lineageTag: cd151967-a682-4e2d-a7c7-5c92c1b76d4e
		summarizeBy: sum
		sourceColumn: DistanceToMetroKM

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column AttractionIndexNorm
		dataType: double
		lineageTag: 25246703-d8ca-419e-afd9-2f04ce1d5488
		summarizeBy: sum
		sourceColumn: AttractionIndexNorm

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

