model Model
	culture: en-GB
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["gold DimLocation","gold DimHostProfile","gold FactListings","gold DimRoom"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'gold DimLocation'
ref table 'gold DimHostProfile'
ref table 'gold FactListings'
ref table 'gold DimRoom'

ref cultureInfo en-GB

